@{
    Layout = "_Layout";
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="page-hd">
    <h2>Tài khoản của tôi</h2>
    <p>Quản lý mật khẩu</p>
</div>

<div class="profile-layout">
    <div class="profile-side">
        <div class="profile-avatar-lg">✦</div>
        <div class="profile-uname">@User.Identity?.Name</div>
        <div class="profile-email">Tài khoản</div>
        <div class="side-menu">
            <a class="side-item" asp-controller="Account" asp-action="Profile"><span>✦</span> Thông tin cá nhân</a>
            <a class="side-item active" asp-controller="Account" asp-action="ChangePassword"><span>✦</span> Đổi mật khẩu</a>
            <div class="side-sep"></div>
            <a class="side-item" asp-controller="Order" asp-action="MyOrders"><span>✦</span> Đơn hàng</a>
            <a class="side-item" asp-controller="Order" asp-action="PurchaseHistory"><span>◇</span> Lịch sử mua hàng</a>
            <div class="side-sep"></div>
            <a class="side-item danger" asp-controller="Account" asp-action="Logout"><span>✕</span> Đăng xuất</a>
        </div>
    </div>

    <div class="profile-main">
        <h3>Đổi mật khẩu</h3>
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div class="field">
                <label for="oldPassword">Mật khẩu cũ <span class="text-danger">*</span></label>
                <input type="password" id="oldPassword" name="oldPassword" placeholder="••••••••" required autofocus />
                @Html.ValidationMessage("oldPassword", new { @class = "text-danger" })
            </div>
            <div class="field">
                <label for="newPassword">Mật khẩu mới <span class="text-danger">*</span></label>
                <input type="password" id="newPassword" name="newPassword" placeholder="Tối thiểu 6 ký tự" required minlength="6" />
                @Html.ValidationMessage("newPassword", new { @class = "text-danger" })
            </div>
            <div class="field">
                <label for="confirmPassword">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Nhập lại mật khẩu mới" required />
                @Html.ValidationMessage("confirmPassword", new { @class = "text-danger" })
            </div>
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="shopvn-alert danger">@Html.ValidationSummary(false)</div>
            }
            <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:20px;">
                <button type="submit" class="btn btn-gold">Cập nhật mật khẩu</button>
                <a asp-action="Profile" class="btn btn-outline btn-sm">← Hồ sơ</a>
            </div>
        </form>
    </div>
</div>
