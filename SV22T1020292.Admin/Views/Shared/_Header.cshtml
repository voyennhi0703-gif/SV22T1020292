@using SV22T1020292.Models.Security
<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            <li class="nav-item d-none d-md-block"><a href="~/" class="nav-link">Trang chủ</a></li>
        </ul>
        <ul class="navbar-nav ms-auto">
            @if (User.Identity?.IsAuthenticated == true)
            {
                var userData = User.GetUserData();
                var displayName = !string.IsNullOrWhiteSpace(userData?.DisplayName)
                    ? userData.DisplayName
                    : (!string.IsNullOrWhiteSpace(userData?.Email)
                        ? userData.Email
                        : User.Identity?.Name ?? "Người dùng");
                var fileName = string.IsNullOrWhiteSpace(userData?.Photo) ? null : System.IO.Path.GetFileName(userData.Photo.Trim());
                var defaultAvatar = Url.Content("~/img/avatar-default.svg");
                var photoSrc = string.IsNullOrEmpty(fileName) ? defaultAvatar : Url.Content($"~/images/employees/{fileName}");
                <li class="nav-item dropdown user-menu">
                    <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                        <img src="@photoSrc" class="user-image rounded-circle shadow" alt="" width="32" height="32"
                             onerror="this.onerror=null;this.src='@defaultAvatar';" />
                        <span class="d-none d-md-inline">@displayName</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                        <li class="user-header text-bg-primary">
                            <img src="@photoSrc" class="rounded-circle shadow" alt="" width="90" height="90"
                                 onerror="this.onerror=null;this.src='@defaultAvatar';" />
                            <p>@displayName</p>
                        </li>
                        <li class="user-footer">
                            <a href="~/Account/ChangePassword" class="btn btn-default btn-flat">Đổi mật khẩu</a>
                            <a href="~/Account/Logout" class="btn btn-default btn-flat float-end">Thoát</a>
                        </li>
                    </ul>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <a href="~/Account/Login" class="nav-link">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                    </a>
                </li>
            }
        </ul>
    </div>
</nav>
