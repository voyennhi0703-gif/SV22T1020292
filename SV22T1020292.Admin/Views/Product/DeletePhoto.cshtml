@{
    ViewData["Title"] = "Xác nhận xóa";
}

<div class="row justify-content-center pt-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-body p-5 text-center">
                <div class="mb-4">
                    <i class="bi bi-trash3-fill text-danger" style="font-size: 4rem; opacity: 0.2;"></i>
                </div>
                <h4 class="fw-bold text-slate-800">Bạn muốn xóa mục này?</h4>
                <p class="text-muted mb-4">
                    Dữ liệu về <b class="text-dark">@ViewBag.ItemName</b> sẽ bị loại bỏ vĩnh viễn khỏi hệ thống mặt hàng này.
                </p>

                <form action="@ViewBag.DeleteUrl" method="post">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2 justify-content-center">
                        <a href="~/Product/Edit/@ViewBag.ProductID" class="btn btn-light px-4 py-2 fw-semibold">
                            <i class="bi bi-x-lg me-1"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-danger px-4 py-2 fw-semibold shadow-sm">
                            <i class="bi bi-trash me-1"></i> Xác nhận xóa ngay
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-danger-subtle border-0 py-2 text-center text-danger small fw-medium">
                Cảnh báo: Thao tác này sẽ cập nhật trực tiếp vào cơ sở dữ liệu.
            </div>
        </div>
    </div>
</div>
