@model PagedResult<OrderViewInfo>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="page-hd">
    <div class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <span>Lịch sử mua hàng</span>
    </div>
    <h2>Lịch sử mua hàng</h2>
    <p>Tất cả đơn hàng bạn đã đặt trên BloomShop · <a asp-action="MyOrders" style="color:var(--rose);font-weight:700;">Theo dõi đơn đang xử lý →</a></p>
</div>

<div class="section" style="padding-top:24px;">
@if (!Model.DataItems.Any())
{
    <div class="empty">
        <div class="empty-icon">📋</div>
        <h3>Chưa có đơn hàng</h3>
        <p class="text-muted">Khi bạn đặt mua, danh sách sẽ hiển thị tại đây.</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-gold">Mua sắm ngay →</a>
    </div>
}
else
{
    <div class="shopvn-card" style="padding:0;overflow:hidden;">
        <table class="table-shopvn history-orders-table">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Ngày đặt</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Tổng tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var o in Model.DataItems)
            {
                string pill = o.Status switch
                {
                    1 => "s-pending",
                    2 => "s-processing",
                    3 => "s-shipping",
                    4 => "s-delivered",
                    -1 => "s-cancel",
                    _ => "s-cancel"
                };
                <tr>
                    <td><strong class="gold">#@o.OrderID</strong></td>
                    <td>@o.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                    <td><span class="status-pill @pill">@o.StatusDescription</span></td>
                    <td class="text-end" style="font-weight:700;color:var(--rose);">@o.TotalAmount.ToString("N0")₫</td>
                    <td class="text-end"><a asp-action="Detail" asp-route-orderId="@o.OrderID" class="btn btn-outline btn-sm">Chi tiết</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <nav class="shopvn-pagination" aria-label="Phân trang">
            @if (Model.HasPreviousPage)
            {
                <a href="?page=@(Model.Page - 1)">‹</a>
            }
            else { <span class="disabled">‹</span> }
            @foreach (var pi in Model.GetDisplayPages(3))
            {
                if (pi.IsEllipsis) { <span>…</span> }
                else if (pi.IsCurrent) { <span class="current">@pi.Page</span> }
                else { <a href="?page=@pi.Page">@pi.Page</a> }
            }
            @if (Model.HasNextPage)
            {
                <a href="?page=@(Model.Page + 1)">›</a>
            }
            else { <span class="disabled">›</span> }
        </nav>
    }
}
</div>
