@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập | BloomShop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/shopvn.css" asp-append-version="true" />
    <style>
        .field-input-wrap {
            position: relative;
        }
        .field-input-wrap .field-input {
            width: 100%;
            background: var(--bg3);
            border: 1.5px solid var(--border);
            border-radius: var(--r-sm);
            padding: 12px 50px 12px 16px;
            font-family: var(--font-body);
            font-size: 14px;
            color: var(--text);
            outline: none;
            transition: all .22s;
            margin-bottom: 0;
        }
        .field-input-wrap .field-input::placeholder { color: var(--text3); }
        .field-input-wrap .field-input:focus {
            border-color: var(--rose);
            box-shadow: 0 0 0 3px var(--rose-dim);
            background: var(--white);
        }
        .field-input-wrap .input-icon {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text3);
            font-size: 18px;
            cursor: pointer;
            transition: all .22s;
            background: none;
            border: none;
            padding: 4px;
        }
        .field-input-wrap .input-icon:hover { color: var(--rose); }
        .field-error {
            font-size: 12px;
            color: var(--danger);
            margin-top: 6px;
            min-height: 18px;
        }
        .login-error {
            background: rgba(212,80,80,.10);
            border: 1.5px solid rgba(212,80,80,.3);
            color: var(--danger);
            padding: 12px 16px;
            border-radius: var(--r-sm);
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>
</head>
<body class="shopvn-body">
<div class="auth-wrap">
    <div class="auth-card">
        <a class="auth-logo" asp-controller="Home" asp-action="Index">BloomShop</a>
        <div class="auth-tagline">MUA SẮM THÔNG MINH — TIẾT KIỆM HƠN</div>
        <div class="auth-title">Chào mừng trở lại</div>
        <div class="auth-sub">Đăng nhập để tiếp tục mua sắm</div>

        <form asp-action="Login" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div class="field">
                <label for="email">Email</label>
                <div class="field-input-wrap">
                    <input type="email" id="email" name="email" class="field-input" placeholder="email@gmail.com" autocomplete="username" autofocus />
                    <span class="input-icon">✉️</span>
                </div>
                <div class="field-error" id="email-error" aria-live="polite"></div>
            </div>
            <div class="field">
                <label for="password">Mật khẩu</label>
                <div class="field-input-wrap">
                    <input type="password" id="password" name="password" class="field-input" placeholder="••••••••" autocomplete="current-password" />
                    <button type="button" class="input-icon" onclick="togglePassword()" id="toggle-pwd-icon">👁️</button>
                </div>
                <div class="field-error" id="password-error" aria-live="polite"></div>
            </div>
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="login-error" style="background:rgba(76,175,80,.10);border-color:rgba(76,175,80,.3);color:#2e7d32;">
                    <span>✓</span>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="login-error">
                    <span>⚠️</span>
                    <span>@Html.ValidationSummary(false)</span>
                </div>
            }
            <button type="submit" class="btn btn-gold btn-full" style="margin-top:8px;">Đăng nhập</button>
        </form>

        <script>
            function togglePassword() {
                var pwd = document.getElementById('password');
                var icon = document.getElementById('toggle-pwd-icon');
                if (pwd.type === 'password') {
                    pwd.type = 'text';
                    icon.textContent = '🙈';
                } else {
                    pwd.type = 'password';
                    icon.textContent = '👁️';
                }
            }

            document.querySelector('form').addEventListener('submit', function(e) {
                var email = document.getElementById('email');
                var password = document.getElementById('password');
                var emailError = document.getElementById('email-error');
                var passwordError = document.getElementById('password-error');
                var hasError = false;

                emailError.textContent = '';
                passwordError.textContent = '';

                if (!email.value.trim()) {
                    emailError.textContent = 'Vui lòng nhập email';
                    hasError = true;
                }

                if (!password.value.trim()) {
                    passwordError.textContent = 'Vui lòng nhập mật khẩu';
                    hasError = true;
                }

                if (hasError) {
                    e.preventDefault();
                }
            });

            document.getElementById('email').addEventListener('input', function() {
                document.getElementById('email-error').textContent = '';
            });

            document.getElementById('password').addEventListener('input', function() {
                document.getElementById('password-error').textContent = '';
            });
        </script>

        <p class="auth-footer" style="margin-top:20px;">
            Chưa có tài khoản?
            <a asp-action="Register" style="color:var(--rose);font-weight:700;">Đăng ký ngay →</a>
        </p>
    </div>
</div>
</body>
</html>
