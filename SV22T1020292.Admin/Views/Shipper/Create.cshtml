@* File: CreateShipper.cshtml *@
@{
    ViewData["Title"] = "Thêm người giao hàng";
}

<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --border: 240 5.9% 90%;
        --input: 240 5.9% 90%;
        --primary: 240 5.9% 10%;
        --ring: 240 5% 64.9%;
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: #fafafa;
    }

    .cn-card {
        background: white;
        border: 1px solid hsl(var(--border));
        border-radius: 0.75rem;
    }

    .cn-input {
        width: 100%;
        border: 1px solid hsl(var(--input));
        border-radius: 0.375rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        outline: none;
        transition: 0.2s;
    }

        .cn-input:focus {
            border-color: hsl(var(--primary));
            ring: 2px solid hsl(var(--ring) / 0.2);
        }

    .cn-btn-black {
        background: hsl(var(--primary));
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        font-weight: 500;
        transition: 0.2s;
    }

        .cn-btn-black:hover {
            opacity: 0.9;
        }

    .cn-btn-outline {
        border: 1px solid hsl(var(--border));
        background: white;
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        transition: 0.2s;
    }

        .cn-btn-outline:hover {
            background: #f4f4f5;
        }

    .sd-label {
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 0.375rem;
        display: block;
        color: #18181b;
    }
</style>

<div class="max-w-3xl mx-auto py-12 px-6">
    <div class="mb-8">
        <nav class="flex text-zinc-400 text-xs uppercase tracking-widest mb-2" aria-label="Breadcrumb">
            <a href="~/Shipper" class="hover:text-zinc-900 transition-colors">Shippers</a>
            <span class="mx-2">/</span>
            <span class="text-zinc-900 font-bold">Thêm mới</span>
        </nav>
        <h1 class="text-3xl font-bold tracking-tight text-zinc-900">Đăng ký Shipper</h1>
        <p class="text-zinc-500 mt-1">Quản lý đội ngũ giao hàng của bạn chuyên nghiệp hơn.</p>
    </div>

    <form action="~/Shipper/Save" method="post" class="space-y-6">
        <div class="cn-card p-8 shadow-sm">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                <div class="md:col-span-2 space-y-2">
                    <label class="sd-label">Tên đầy đủ / Tên công ty <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <i class="bi bi-truck absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400"></i>
                        <input type="text" name="ShipperName" class="cn-input pl-10" placeholder="VD: Viettel Post, Nguyễn Văn A..." required>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="sd-label">Số điện thoại liên hệ</label>
                    <div class="relative">
                        <i class="bi bi-telephone absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400"></i>
                        <input type="tel" name="Phone" class="cn-input pl-10" placeholder="09xxxxxxx">
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="sd-label">Phương thức giao hàng</label>
                    <select name="Type" class="cn-input bg-white appearance-none">
                        <option value="Road">Đường bộ (Xe máy/Xe tải)</option>
                        <option value="Air">Đường hàng không</option>
                        <option value="Express">Hỏa tốc</option>
                    </select>
                </div>

                <div class="md:col-span-2 space-y-2">
                    <label class="sd-label">Khu vực phụ trách</label>
                    <input type="text" name="Region" class="cn-input" placeholder="VD: Quận 1, Quận 3, Toàn quốc...">
                </div>

                <div class="md:col-span-2 space-y-2">
                    <label class="sd-label">Thông tin bổ sung</label>
                    <textarea name="Description" class="cn-input min-h-[100px]" placeholder="Các lưu ý về khung giờ giao hàng, bảng giá..."></textarea>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-between pt-2">
            <a href="~/Shipper" class="cn-btn-outline px-8">
                <i class="bi bi-chevron-left me-2"></i>Quay lại
            </a>
            <div class="flex gap-3">
                <button type="reset" class="cn-btn-outline">Làm mới</button>
                <button type="submit" class="cn-btn-black px-10 shadow-lg shadow-zinc-200">
                    Lưu thông tin
                </button>
            </div>
        </div>
    </form>
</div>
