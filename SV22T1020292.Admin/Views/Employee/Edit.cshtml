@model SV22T1020292.Models.HR.Employee
@{
    ViewBag.Title = ViewBag.Title ?? "Cập nhật nhân viên";
    var photoFile = string.IsNullOrWhiteSpace(Model.Photo) ? "no-photo.png" : Model.Photo;
}
<style>
    .field-error {
        border-color: #dc3545 !important;
        background-color: #fff8f8 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.15);
    }
    .field-error-message {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 4px;
        display: none;
    }
    .field-error-message.show {
        display: block;
    }
</style>
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    Thông tin nhân viên
                </h5>
            </div>

            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" role="alert">
                        <ul class="mb-0 ps-3">
                            @foreach (var entry in ViewData.ModelState.Values)
                            {
                                foreach (var err in entry.Errors)
                                {
                                    <li>@err.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form id="formEdit" action="~/Employee/Save" method="post" enctype="multipart/form-data" novalidate>
                    <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />
                    <input type="hidden" name="RoleNames" value="@Model.RoleNames" />
                    <input type="hidden" name="Photo" value="@photoFile" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" for="FullName">Họ và tên</label>
                        <div class="col-sm-5">
                            <input type="text"
                                   class="form-control"
                                   name="FullName"
                                   id="FullName"
                                   value="@Model.FullName"
                                   placeholder="Nhập họ và tên"
                                   autofocus />
                            <div class="field-error-message" id="FullName-error">Vui lòng nhập Họ và tên</div>
                        </div>
                        <label class="col-sm-2 col-form-label text-end" for="BirthDate">Ngày sinh</label>
                        <div class="col-sm-2">
                            <input type="date"
                                   class="form-control"
                                   name="BirthDate"
                                   id="BirthDate"
                                   value="@(Model.BirthDate.HasValue ? Model.BirthDate.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" for="Phone">Điện thoại</label>
                        <div class="col-sm-2">
                            <input type="tel"
                                   class="form-control"
                                   name="Phone"
                                   id="Phone"
                                   value="@Model.Phone"
                                            placeholder="Nhập số điện thoại" />
                            <div class="field-error-message" id="Phone-error">Vui lòng nhập Điện thoại</div>
                            <div class="field-error-message" id="Phone-notdigit-error">Số điện thoại chỉ được nhập số (0-9) và dấu chấm (.)</div>
                        </div>
                        <label class="col-sm-1 col-form-label text-end" for="Email">Email</label>
                        <div class="col-sm-6">
                            <input type="email"
                                   class="form-control"
                                   name="Email"
                                   id="Email"
                                   value="@Model.Email"
                                   placeholder="Nhập địa chỉ email" />
                            <div class="field-error-message" id="Email-error">Vui lòng nhập Email</div>
                            <div class="field-error-message" id="Email-at-error">Email phải chứa ký tự @@</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" for="Address">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea class="form-control"
                                      name="Address"
                                      id="Address"
                                      rows="3"
                                        placeholder="Nhập địa chỉ">@Model.Address</textarea>
                            <div class="field-error-message" id="Address-error">Vui lòng nhập Địa chỉ</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   class="form-control"
                                   name="uploadPhoto"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/employees/@photoFile"
                                     class="img-thumbnail"
                                     style="max-height: 150px;"
                                     alt=""
                                     onerror="this.src='@Url.Content("~/images/employees/no-photo.png")'" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <input type="hidden" name="IsWorking" value="false" />
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsWorking"
                                       value="true"
                                       id="IsWorking"
                                       @(Model.IsWorking == true ? "checked" : "") />
                                <label class="form-check-label" for="IsWorking">
                                        Đang làm việc
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('formEdit').addEventListener('submit', function (e) {
        var isValid = true;

        function clearErr(id) {
            var el = document.getElementById(id);
            if (el) { el.classList.remove('field-error'); }
            var m = document.getElementById(id + '-error');
            if (m) m.classList.remove('show');
        }

        ['FullName', 'Phone', 'Email', 'Address'].forEach(function (id) {
            clearErr(id);
            var input = document.getElementById(id);
            if (!input) return;
            var err = document.getElementById(id + '-error');
            var val = input.value.trim();
            if (val === '') {
                input.classList.add('field-error');
                if (err) err.classList.add('show');
                isValid = false;
            }
            if (id === 'Phone' && val !== '' && !/^[\d.]+$/.test(val)) {
                input.classList.add('field-error');
                if (err) err.classList.remove('show');
                document.getElementById('Phone-notdigit-error').classList.add('show');
                isValid = false;
            }
            if (id === 'Email' && val !== '') {
                var gmailErr = document.getElementById('Email-gmail-error');
                if (gmailErr) gmailErr.classList.remove('show');
                if (!val.toLowerCase().includes('@@')) {
                    input.classList.add('field-error');
                    if (err) err.classList.remove('show');
                    var atErr = document.getElementById('Email-at-error');
                    if (atErr) atErr.classList.add('show');
                    isValid = false;
                }
            }
        });

        if (!isValid) e.preventDefault();
    });

    ['FullName', 'Phone', 'Email', 'Address'].forEach(function (id) {
        var input = document.getElementById(id);
        if (!input) return;
        input.addEventListener('input', function () {
            input.classList.remove('field-error');
            var err = document.getElementById(id + '-error');
            if (err) err.classList.remove('show');
            var nd = document.getElementById(id + '-notdigit-error');
            if (nd) nd.classList.remove('show');
            if (id === 'Email') {
                var g = document.getElementById('Email-at-error');
                if (g) g.classList.remove('show');
            }
        });
    });
</script>
