@model PagedResult<OrderViewInfo>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Đơn hàng";
}

<div class="page-hd">
    <div class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <span>Đơn hàng</span>
    </div>
    <h2>Đơn hàng</h2>
    <p>Theo dõi tiến trình các đơn đang xử lý (chờ xác nhận, đang giao…)</p>
</div>

<div class="section" style="padding-top:24px;">
@if (!Model.DataItems.Any())
{
    <div class="empty">
        <div class="empty-icon">🛍</div>
        <h3>Không có đơn đang xử lý</h3>
        <p class="text-muted">Các đơn đã giao hoặc đã hủy nằm trong <a asp-action="PurchaseHistory" style="color:var(--rose);font-weight:700;">lịch sử mua hàng</a>.</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-gold">Mua sắm ngay →</a>
    </div>
}
else
{
    @foreach (var o in Model.DataItems)
    {
        string pill = o.Status switch
        {
            1 => "s-pending",
            2 => "s-processing",
            3 => "s-shipping",
            4 => "s-delivered",
            -1 => "s-cancel",
            _ => "s-cancel"
        };
        var steps = new[] { "Chờ xác nhận", "Đang xử lý", "Đang giao", "Đã giao" };
        var curIdx = o.Status >= 1 && o.Status <= 4 ? o.Status - 1 : -1;
        <div class="order-card order-card--track">
            <div class="order-header">
                <div>
                    <div class="order-id">#@o.OrderID</div>
                    <div class="order-date">📅 @o.OrderTime.ToString("dd/MM/yyyy HH:mm") · @(o.CustomerName ?? "—")</div>
                </div>
                <span class="status-pill @pill">@o.StatusDescription</span>
            </div>
            @if (curIdx >= 0)
            {
                <div class="timeline">
                    @for (int i = 0; i < steps.Length; i++)
                    {
                        <div class="tl-step @(i < curIdx ? "done" : i == curIdx ? "curr" : "")">
                            <div class="tl-dot">@(i < curIdx ? "✓" : i + 1)</div>
                            <div class="tl-label">@steps[i]</div>
                        </div>
                    }
                </div>
            }
            <div class="text-muted" style="font-size:13px;line-height:1.6;margin-top:8px;">
                <div>@(o.CustomerPhone ?? "") · @(o.DeliveryProvince ?? "")</div>
                <div>@(o.DeliveryAddress ?? "—")</div>
            </div>
            <div class="order-footer">
                <span class="text2">@(o.CustomerName ?? "—")</span>
                <div class="order-total">@o.TotalAmount.ToString("N0")₫</div>
            </div>
            <div style="margin-top:12px;">
                <a asp-action="Detail" asp-route-orderId="@o.OrderID" class="btn btn-outline btn-sm">Chi tiết →</a>
            </div>
        </div>
    }

    @if (Model.PageCount > 1)
    {
        <nav class="shopvn-pagination" aria-label="Phân trang">
            @if (Model.HasPreviousPage)
            {
                <a href="?page=@(Model.Page - 1)">‹</a>
            }
            else { <span class="disabled">‹</span> }
            @foreach (var pi in Model.GetDisplayPages(3))
            {
                if (pi.IsEllipsis) { <span>…</span> }
                else if (pi.IsCurrent) { <span class="current">@pi.Page</span> }
                else { <a href="?page=@pi.Page">@pi.Page</a> }
            }
            @if (Model.HasNextPage)
            {
                <a href="?page=@(Model.Page + 1)">›</a>
            }
            else { <span class="disabled">›</span> }
        </nav>
    }
    <p class="text-muted" style="margin-top:20px;font-size:13px;text-align:center;">
        Đơn đã giao / đã hủy: <a asp-action="PurchaseHistory" style="color:var(--rose);font-weight:700;">Lịch sử mua hàng →</a>
    </p>
}
</div>
