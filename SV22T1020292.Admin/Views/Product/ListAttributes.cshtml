@using System
@using SV22T1020292.Models.Catalog
@{
    Layout = null;
    var pid = ViewBag.ProductGalleryId != null ? Convert.ToInt32(ViewBag.ProductGalleryId) : 0;
    var attributes = ViewBag.ProductAttributes as IReadOnlyList<ProductAttribute> ?? Array.Empty<ProductAttribute>();
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="attributes" class="card-title mb-0">
                            <i class="bi bi-list-check me-2"></i>
                            Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        @if (pid > 0)
                        {
                            <a class="btn btn-sm btn-primary" href="~/Product/CreateAttribute/@pid">
                                <i class="bi bi-plus"></i>
                                Thêm thuộc tính
                            </a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-secondary" disabled title="Lưu mặt hàng trước khi thêm thuộc tính">
                                <i class="bi bi-plus"></i>
                                Thêm thuộc tính
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (attributes.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    Chưa có thuộc tính trong cơ sở dữ liệu cho mặt hàng này.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var a in attributes)
                            {
                                <tr>
                                    <td>@a.AttributeName</td>
                                    <td>@(string.IsNullOrWhiteSpace(a.AttributeValue) ? "—" : a.AttributeValue)</td>
                                    <td class="text-center">@a.DisplayOrder</td>
                                    <td class="text-center text-nowrap">
                                        @if (pid > 0)
                                        {
                                            <a class="btn btn-sm btn-primary" href="~/Product/EditAttribute/@pid?attributeId=@a.AttributeID">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a class="btn btn-sm btn-danger" href="~/Product/DeleteAttribute/@pid?attributeId=@a.AttributeID">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
