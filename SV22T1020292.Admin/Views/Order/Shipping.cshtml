@model SV22T1020292.Admin.Models.OrderShippingDialogModel
@{
    Layout = null;
}
<form asp-action="Shipping" asp-route-id="@Model.OrderId" method="post">
    @Html.AntiForgeryToken()
    <div class="modal-header text-bg-primary">
        <strong class="modal-title">
            Chuyển giao hàng — đơn #@Model.OrderId
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="alert alert-primary d-flex align-items-center">
            <i class="bi bi-truck me-2"></i>
            Chọn người (đơn vị) giao hàng. Sau bước này đơn chuyển sang trạng thái <strong>đang giao</strong>.
        </div>
        <div class="mb-0">
            <label class="form-label">Người giao hàng <span class="text-danger">*</span></label>
            <select name="shipperId" class="form-select" required>
                <option value="">-- Chọn người giao hàng --</option>
                @foreach (var s in Model.Shippers)
                {
                    <option value="@s.ShipperID">@s.ShipperName@(string.IsNullOrEmpty(s.Phone) ? "" : $" — {s.Phone}")</option>
                }
            </select>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-box-seam"></i> Xác nhận chuyển giao
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>
