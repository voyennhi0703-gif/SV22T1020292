@model SV22T1020292.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = ViewBag.Title ?? "Thuộc tính mặt hàng";
    var productName = ViewBag.ProductName as string;
}
@section PageToolBar {
    <button type="submit" form="formAttribute" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>
    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-list-check me-2"></i>
                    @ViewBag.Title
                </h5>
                @if (!string.IsNullOrWhiteSpace(productName))
                {
                    <p class="small text-muted mb-0 mt-1">Mặt hàng: <strong>@productName</strong></p>
                }
            </div>

            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" role="alert">
                        <ul class="mb-0 ps-3">
                            @foreach (var entry in ViewData.ModelState.Values)
                            {
                                foreach (var err in entry.Errors)
                                {
                                    <li>@err.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form id="formAttribute" method="post" action="~/Product/SaveAttribute" novalidate>
                    <input type="hidden" name="AttributeID" value="@Model.AttributeID" />
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold" for="AttributeName">Tên thuộc tính</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   id="AttributeName"
                                   name="AttributeName"
                                   class="form-control"
                                   value="@Model.AttributeName"
                                   placeholder="Ví dụ: Màu sắc, Kích thước"
                                   autofocus
                                   required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold" for="AttributeValue">Giá trị</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   id="AttributeValue"
                                   name="AttributeValue"
                                   class="form-control"
                                   value="@Model.AttributeValue"
                                   placeholder="Ví dụ: Đỏ, XL, 500g"
                                   required />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold" for="DisplayOrder">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number"
                                   id="DisplayOrder"
                                   name="DisplayOrder"
                                   class="form-control"
                                   value="@(Model.DisplayOrder <= 0 ? 1 : Model.DisplayOrder)"
                                   min="1" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
