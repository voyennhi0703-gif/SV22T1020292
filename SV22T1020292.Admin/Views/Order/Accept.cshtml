@model SV22T1020292.Admin.Models.OrderAcceptDialogModel
@{
    Layout = null;
}
<form asp-action="Accept" asp-route-id="@Model.OrderId" method="post">
    @Html.AntiForgeryToken()
    <div class="modal-header text-bg-info">
        <strong class="modal-title">
            Duyệt chấp nhận đơn hàng #@Model.OrderId
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="alert alert-info d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Chọn nhân viên phụ trách trước khi duyệt đơn.
        </div>
        <div class="mb-0">
            <label class="form-label">Nhân viên phụ trách <span class="text-danger">*</span></label>
            <select name="employeeId" class="form-select" required>
                <option value="">-- Chọn nhân viên --</option>
                @foreach (var e in Model.Employees)
                {
                    <option value="@e.EmployeeID">@e.FullName</option>
                }
            </select>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check"></i> Chấp nhận đơn
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>
