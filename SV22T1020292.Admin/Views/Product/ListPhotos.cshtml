@using System
@using SV22T1020292.Models.Catalog
@{
    Layout = null;
    var pid = ViewBag.ProductGalleryId != null ? Convert.ToInt32(ViewBag.ProductGalleryId) : 0;
    var photos = ViewBag.ProductPhotos as IReadOnlyList<ProductPhoto> ?? Array.Empty<ProductPhoto>();
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        @if (pid > 0)
                        {
                            <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@pid">
                                <i class="bi bi-plus-circle me-1"></i>
                                Thêm ảnh
                            </a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-secondary" disabled title="Lưu mặt hàng trước khi thêm ảnh">
                                <i class="bi bi-plus-circle me-1"></i>
                                Thêm ảnh
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (photos.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    Chưa có ảnh trong cơ sở dữ liệu cho mặt hàng này.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var p in photos)
                            {
                                var img = string.IsNullOrWhiteSpace(p.Photo) ? "nophoto.png" : p.Photo;
                                <tr>
                                    <td class="text-center">
                                        <img src="~/images/products/@img"
                                             class="img-thumbnail"
                                             style="max-height:80px;"
                                             alt=""
                                             onerror="this.src='@Url.Content("~/images/products/nophoto.png")'" />
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(p.Description) ? "—" : p.Description)</td>
                                    <td class="text-center">@p.DisplayOrder</td>
                                    <td class="text-center">
                                        @if (p.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap">
                                        @if (pid > 0)
                                        {
                                            <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@pid?photoId=@p.PhotoID">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/@pid?photoId=@p.PhotoID">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
